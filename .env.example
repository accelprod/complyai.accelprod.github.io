# ============================================================
# ComplyAI website — environment variable template
# ------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# Formspree form ID for the demo-request form.
# Create a form at https://formspree.io and paste its ID below.
# Without this, the demo form refuses to submit and shows a real
# error rather than a fake success.
NEXT_PUBLIC_FORMSPREE_ID=

# Plausible analytics domain. Set to your live domain (e.g.
# complai.dev). Leave blank in dev to disable analytics locally.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Canonical site URL used by sitemap.xml, JSON-LD, and Open
# Graph metadata. No trailing slash. Defaults to https://complai.dev
# in lib/seo.ts if unset.
NEXT_PUBLIC_SITE_URL=https://complai.dev
